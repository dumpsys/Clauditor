{
  "name": "clauditor",
  "version": "1.0.0",
  "description": "An autonomous PR auditor powered by Claude Code. Listens to GitHub webhooks, applies review feedback, and reviews PRs on request.",
  "type": "module",
  "main": "src/server.js",
  "license": "Apache-2.0",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --test",
    "test:coverage": "node --experimental-test-coverage --test",
    "test:webhook": "node scripts/test-webhook.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^4.18.2"
  }
}
