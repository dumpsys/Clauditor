# ─────────────────────────────────────────────
# Clauditor — Environment Variables
# Copy this to .env and fill in your values.
# Never commit .env to git.
# ─────────────────────────────────────────────

# GitHub Personal Access Token (or fine-grained token)
# Needs: pull_requests:write, contents:write, issues:write
# If not provided, it will try to obtain token from system envar (eg. ~/.zshrc)
GITHUB_TOKEN=ghp_your_token_here

# Secret set in GitHub webhook settings (Settings → Webhooks → Secret)
GITHUB_WEBHOOK_SECRET=your_random_webhook_secret

# The GitHub username of the account/bot posting replies (to prevent loop)
GITHUB_BOT_USERNAME=your-github-username

# Username that, when requested as a reviewer on a PR, triggers an automated
# `/review` run posted as a formal PR review. Leave empty to disable.
GITHUB_REVIEW_REQUEST_USER=

# Edit-an-existing-comment-and-add-this-phrase mechanism: when a user EDITS
# an issue_comment to include this phrase, the bot re-evaluates the feedback
# (case-insensitive). The phrase is stripped before Claude sees the body.
# Empty disables the issue_comment.edited workflow.
CLAUDITOR_TRIGGER_PHRASE=Clauditor verify this

# Branches the bot must NEVER push to (comma-separated)
PROTECTED_BRANCHES=main,master,develop

# Port for the local server
PORT=3000

# Git commit identity
GIT_EMAIL=pr-bot@yourdomain.com
GIT_NAME=PR Review Bot
# Optional: the bot account's numeric GitHub user ID. When set, commits are
# authored with the GitHub no-reply email
# (<id>+GITHUB_BOT_USERNAME@users.noreply.github.com) and GIT_EMAIL is ignored.
# Use this when the account has "Keep my email address private" enabled,
# otherwise pushes fail with "GH007: Your push would publish a private email".
# Find the ID at https://api.github.com/users/<username> (the "id" field).
GITHUB_NOREPLY_USER_ID=

# Timeout for Claude Code execution in milliseconds.
# CLAUDE_TIMEOUT_MS         applies to the comment handler (one targeted edit). Default: 5 min.
# CLAUDE_REVIEW_TIMEOUT_MS  applies to /review jobs which are far heavier.    Default: 20 min.
CLAUDE_TIMEOUT_MS=300000
CLAUDE_REVIEW_TIMEOUT_MS=1200000

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Log timestamp format. By default logs use the machine's local timezone with
# an explicit UTC offset (e.g. "2026-05-04T11:06:44.123+07:00") so they're
# easy to correlate with the wall clock. Set LOG_UTC=true to force UTC ("…Z").
# LOG_UTC=true

# Override path to the tailscale CLI if it isn't on PATH inside scripts.
# Useful on macOS when only the standalone Tailscale.app is installed
# (shell aliases in ~/.zshrc don't propagate into non-interactive scripts).
# TAILSCALE_BIN=/Applications/Tailscale.app/Contents/MacOS/Tailscale

# ─────────────────────────────────────────────
# Sentry (Workflow C — crash-to-PR)
# Leave SENTRY_CLIENT_SECRET unset to disable.
# ─────────────────────────────────────────────

# Client Secret of the Sentry Internal Integration. Required to verify
# webhook HMAC signatures. Setting this turns on Workflow C and makes the
# other SENTRY_* vars required.
SENTRY_CLIENT_SECRET=

# Auth Token from the same Internal Integration. Needs scopes:
#   event:read, project:read, issue:write (to post comments back).
SENTRY_AUTH_TOKEN=

# Map Sentry project slugs to GitHub repos. Comma-separated entries of the
# form "<sentry-project-slug>:<github-owner>/<github-repo>".
# Example: "my-rn-app:hakim/my-rn-app,api-server:hakim/api-server"
SENTRY_PROJECT_REPO_MAP=

# Override only if you use a self-hosted Sentry instance.
# SENTRY_API_BASE_URL=https://sentry.io/api/0

# Branch to base new fix branches off of (when no existing fix branch found).
SENTRY_BASE_BRANCH=main

# Prefix for auto-generated fix branches. Branch name is `${prefix}${issueId}`.
SENTRY_BRANCH_PREFIX=sentry-fix/

# Minimum event count for an issue to trigger a fix attempt. Set higher
# (e.g. 10) to ignore one-off errors and only act on recurring crashes.
SENTRY_MIN_EVENT_COUNT=1

# How many Sentry issues to process in parallel. Different issues run
# concurrently; duplicate webhooks for the same issue are deduplicated.
SENTRY_MAX_CONCURRENT_JOBS=2

# Timeout for the Sentry-fix Claude run (ms). Crash investigations are
# heavier than addressing a single review comment — default 10 minutes.
SENTRY_CLAUDE_TIMEOUT_MS=600000
